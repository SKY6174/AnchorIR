# Supabase 접속 URL (Supabase Project Settings -> API 메뉴에서 확인 가능)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 익명 public API Key (Anon Key)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 구글 제미나이(Gemini) 또는 OpenAI API 키 연동 설정 (로컬 개발 RAG 테스트용)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_OPENAI_API_KEY=your_openai_api_key_here

# OTP remains unavailable until both the feature and provider readiness flags are true.
VITE_ENABLE_EMAIL_OTP=false
VITE_EMAIL_OTP_PROVIDER_READY=false
VITE_ENABLE_SMS_OTP=false
VITE_SMS_OTP_PROVIDER_READY=false
VITE_OTP_RESEND_COOLDOWN_MS=60000
VITE_OTP_MAX_VERIFY_FAILURES=5

# PAdES remains disabled until an approved HSM/signing provider and TSA are configured.
VITE_ENABLE_PADES_SIGNING=false
VITE_PADES_PROVIDER_READY=false
